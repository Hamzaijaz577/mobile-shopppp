# Port the API server runs on
PORT=5050

# --- Email settings (used to notify the shop owner of new orders) ---
# The Gmail account that SENDS the notification email.
# It must be a real Gmail address with an "App Password" (not your normal password).
# How to get an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Turn on 2-Step Verification (required)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create an app password for "Mail" and paste the 16-character code below (no spaces)
EMAIL_USER=hijaz8072@gmail.com
EMAIL_PASS=gcltqtqsidflthdj


# The address that RECEIVES the order notification (the shop owner's inbox)
OWNER_EMAIL=hijaz8072@gmail.com

# Frontend origin allowed to call this API (for CORS)
CLIENT_ORIGIN=http://localhost:5173
